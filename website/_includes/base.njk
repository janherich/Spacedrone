<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}">
</head>
<body>
  <header class="site-header">
    <div class="wrap">
      <a href="{{ '/' | url }}" class="site-title">{{ site.title }}</a>
      <nav class="site-nav">
        {% for item in site.nav %}
          <a href="{{ item.url | url }}"{% if item.url == page.url %} class="active"{% endif %}>{{ item.label }}</a>
        {% endfor %}
      </nav>
    </div>
  </header>
  <main class="site-main wrap">
    <div class="page-content content-from-markdown">
      {{ content | safe }}
    </div>
  </main>
  <footer class="site-footer">
    <div class="wrap">
      <p><a href="{{ site.repo }}">GitHub</a> · Open-source drone design · <a href="mailto:{{ site.contact }}">Contact</a> ({{ site.contact }})</p>
    </div>
  </footer>
</body>
</html>
