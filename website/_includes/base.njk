<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <link rel="icon" href="{{ '/assets/favicon.svg' | url }}" type="image/svg+xml">
  <link rel="apple-touch-icon" href="{{ '/assets/favicon.svg' | url }}">
  <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}">
  {% if site.analytics and site.analytics.googleAnalyticsId %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.analytics.googleAnalyticsId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag("js", new Date());
    gtag("config", "{{ site.analytics.googleAnalyticsId }}");
  </script>
  {% endif %}
  <script>window.__PATH_PREFIX__ = {{ pathPrefix | dump | safe }};</script>
</head>
<body>
  <header class="site-header">
    <div class="wrap">
      <a href="{{ '/' | url }}" class="site-title">{{ site.title }}</a>
      <nav class="site-nav">
        {% for item in site.nav %}
          {% set navActive = false %}
          {% if item.url == '/' %}
            {% set navActive = (page.url == '/' or page.url == '/index.html') %}
          {% else %}
            {% set navActive = (page.url == item.url) or (item.url != '/' and page.url.indexOf(item.url) == 0) %}
          {% endif %}
          <a href="{{ item.url | url }}"{% if navActive %} class="active"{% endif %}>{{ item.label }}</a>
        {% endfor %}
      </nav>
    </div>
  </header>
  <main class="site-main wrap">
    <div class="page-content content-from-markdown">
      {{ content | safe }}
    </div>
  </main>
  <footer class="site-footer">
    <div class="wrap">
      <p><a href="{{ site.repo }}" data-track-event="GitHub Click">GitHub</a> · Open-source drone design · <a href="mailto:{{ site.contact }}" data-track-event="Contact Click">Contact</a> ({{ site.contact }})</p>
    </div>
  </footer>
  <script>
  function trackEvent(name, props) {
    if (typeof window.gtag !== "function") return;
    window.gtag("event", name, props || {});
  }
  /** Legacy #hash tab links from the old single-page tabs → real URLs */
  (function() {
    var hash = window.location.hash.replace(/^#/, "");
    if (!hash) return;
    var prefix = typeof window.__PATH_PREFIX__ === "string" ? window.__PATH_PREFIX__ : "";
    var pathname = window.location.pathname;
    var rel = pathname.startsWith(prefix) ? pathname.slice(prefix.length) : pathname;
    if (!rel.startsWith("/")) rel = "/" + rel;
    if (!rel.endsWith("/")) rel += "/";
    var map = {
      "/5-inch/": { build: "/5-inch/build-guide/", sample: "/5-inch/" },
      "/5-inch-hd/": { build: "/5-inch-hd/build-guide/", sample: "/5-inch-hd/" },
      "/7-inch/": { build: "/7-inch/build-guide/", sample: "/7-inch/", stiffness: "/7-inch/stiffness/" }
    };
    var targets = map[rel];
    if (!targets || !targets[hash]) return;
    var dest = prefix + targets[hash];
    if (pathname !== dest) {
      location.replace(dest + window.location.search);
    }
  })();
  document.addEventListener("click", function(e) {
    var trackable = e.target.closest("[data-track-event]");
    if (trackable) {
      trackEvent(trackable.dataset.trackEvent);
    }
    var carouselBtn = e.target.closest(".carousel-btn");
    if (carouselBtn) {
      var carousel = carouselBtn.closest(".carousel");
      var track = carousel.querySelector(".carousel-track");
      var slides = track.children;
      if (!slides.length) return;
      var dots = carousel.querySelectorAll(".carousel-dot");
      var currentTransform = parseFloat(track.style.transform.replace("translateX(", "")) || 0;
      var current = Math.round(Math.abs(currentTransform) / 100);
      if (carouselBtn.classList.contains("carousel-next")) {
        current = (current + 1) % slides.length;
        trackEvent("Carousel Navigate", { direction: "next" });
      } else {
        current = (current - 1 + slides.length) % slides.length;
        trackEvent("Carousel Navigate", { direction: "previous" });
      }
      track.style.transform = "translateX(-" + (current * 100) + "%)";
      dots.forEach(function(d, i) { d.classList.toggle("active", i === current); });
      return;
    }
    var dot = e.target.closest(".carousel-dot");
    if (dot) {
      var carousel = dot.closest(".carousel");
      var track = carousel.querySelector(".carousel-track");
      var dots = carousel.querySelectorAll(".carousel-dot");
      var idx = Array.prototype.indexOf.call(dots, dot);
      track.style.transform = "translateX(-" + (idx * 100) + "%)";
      dots.forEach(function(d, i) { d.classList.toggle("active", i === idx); });
      trackEvent("Carousel Navigate", { direction: "dot", slide: String(idx + 1) });
    }
  });
  </script>
</body>
</html>
